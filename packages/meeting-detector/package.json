{
  "name": "@mostrom/meeting-detector",
  "version": "1.0.4",
  "description": "Real-time meeting detection for macOS desktop apps",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "native/**/*",
    "meeting-detect.sh",
    "README.md",
    "*.node"
  ],
  "scripts": {
    "build": "npm run build:native && npm run build:ts",
    "build:ts": "tsc",
    "build:native": "napi build --cwd native --package-json-path ../package.json --output-dir ..",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "watch": "tsc -w",
    "prepublishOnly": "npm run build",
    "publish:npm": "bash ./scripts/publish-npm.sh"
  },
  "keywords": [
    "meeting",
    "detection",
    "macos",
    "tcc",
    "privacy"
  ],
  "author": "Kaiser White <kaise@mostrom.io>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mostrom-LLC/meeting-detector.git"
  },
  "homepage": "https://github.com/Mostrom-LLC/meeting-detector#readme",
  "bugs": {
    "url": "https://github.com/Mostrom-LLC/meeting-detector/issues"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
